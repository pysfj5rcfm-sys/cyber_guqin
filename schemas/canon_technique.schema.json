{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cyber Guqin Canon Technique",
  "type": "object",
  "required": ["technique_id", "name_zh", "category", "primary_sound_type", "gesture_family", "review_status"],
  "properties": {
    "technique_id": { "type": "string" },
    "name_zh": { "type": "string" },
    "name_alias": { "type": "array", "items": { "type": "string" } },
    "category": { "type": "string" },
    "definition": { "type": "string" },
    "primary_sound_type": { "type": "string", "enum": ["散音", "按音", "泛音", "none"] },
    "sound_profile": { "type": "string" },
    "gesture_family": {
      "type": "string",
      "enum": ["single_pluck", "pressed_pluck", "harmonic_pluck", "simultaneous_pluck", "right_hand_sequence", "left_hand_sound", "post_motion", "vibrato", "open_pressed_harmony", "compound_both_hands", "tempo_expression"]
    },
    "component_rules": { "type": "array", "items": { "type": "object" } },
    "cyber_guqin_mapping": { "type": "object" },
    "source_refs": { "type": "array", "items": { "type": "string" } },
    "review_status": { "type": "string", "enum": ["draft", "reviewed", "verified"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
