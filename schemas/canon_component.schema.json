{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cyber Guqin Canon Component",
  "type": "object",
  "required": ["component_name", "zh_name", "component_category", "hand", "standard_internal_name", "review_status"],
  "properties": {
    "component_name": { "type": "string" },
    "zh_name": { "type": "string" },
    "component_category": {
      "type": "string",
      "enum": ["pluck", "pre_slide", "single_slide", "returning_slide", "micro_returning_slide", "vibrato", "left_sound", "right_sequence", "simultaneous_pluck", "open_pressed_harmony", "compound_both_hands"]
    },
    "hand": { "type": "string", "enum": ["left", "right", "both", "none"] },
    "standard_internal_name": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "description": { "type": "string" },
    "source_refs": { "type": "array", "items": { "type": "string" } },
    "review_status": { "type": "string", "enum": ["draft", "reviewed", "verified"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
